# PostgreSQL bağlantı URL'i
# Örnek: postgresql://kullanici:sifre@localhost:5432/koop_db
DATABASE_URL=postgresql://koop_user:guclu_sifre@localhost:5432/koop_db

# JWT imzalama anahtarı - üretimde mutlaka değiştir!
JWT_SECRET=buraya-cok-uzun-ve-rastgele-bir-anahtar-yaz

# Sunucu portu (opsiyonel, varsayılan: 3000)
PORT=3000

# Log seviyesi
RUST_LOG=info
